# Keep shell + node scripts LF so they run on WSL/Linux/macOS after a Windows checkout
scripts/usage-check    text eol=lf
*.mjs                  text eol=lf
*.sh                   text eol=lf

# Binary assets must never be line-ending converted
*.jpg                  binary
*.jpeg                 binary
*.png                  binary

# Packaged Cowork plugin is a zip - never line-ending convert it
*.plugin               binary
